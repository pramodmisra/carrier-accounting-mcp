# Caddy reverse proxy for agency.5gvector.com
# Caddy handles automatic HTTPS via Let's Encrypt

agency.5gvector.com {
    # Frontend (Next.js)
    handle {
        reverse_proxy web:3000
    }

    # API routes
    handle /api/* {
        reverse_proxy api:8001
    }

    # API docs
    handle /docs* {
        reverse_proxy api:8001
    }
    handle /redoc* {
        reverse_proxy api:8001
    }
    handle /openapi.json {
        reverse_proxy api:8001
    }

    # Security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
    }

    # Compression
    encode gzip zstd

    log {
        output file /var/log/caddy/agency.5gvector.com.log
    }
}
