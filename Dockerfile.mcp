FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc libpq-dev && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt uvicorn

COPY mcp_server/ mcp_server/
COPY data_lake/ data_lake/
COPY carrier_configs/ carrier_configs/

RUN useradd -m -u 1000 appuser && \
    mkdir -p uploads exports && \
    chown -R appuser:appuser /app uploads exports

USER appuser

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/health')" || exit 1

EXPOSE 8000

# Use the HTTP server for cloud deployment
CMD ["uvicorn", "mcp_server.server_http:app", "--host", "0.0.0.0", "--port", "8000"]
